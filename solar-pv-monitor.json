          }
        },
        {
          "refId": "Grid",
          "rawSql": "SELECT power_sensor AS grid_w FROM \"Smart Meter\" ORDER BY time DESC LIMIT 1",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "dark-gray"
              },
              {
                "value": 0.3,
                "color": "yellow"
              },
              {
                "value": 0.7,
                "color": "green"
              },
              {
                "value": 1,
                "color": "dark-green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "binary": {
              "left": "east_w",
              "operator": "+",
              "right": "west_w"
            },
            "alias": "solar_w"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "solar_w",
              "operator": "+",
              "right": "grid_w"
            },
            "alias": "total_w"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "solar_w",
              "operator": "/",
              "right": "total_w"
            },
            "alias": "self_consumption"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "self_consumption"
              ]
            }
          }
        }
      ]
    },
