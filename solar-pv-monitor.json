{
  "__inputs": [
    {
      "name": "DS_INFLUXDB_SOLAR",
      "label": "influxdb-solar",
      "description": "InfluxDB 3 Core - Solar monitoring database",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.4.1" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "id": null,
  "uid": null,
  "title": "Solar PV Monitor",
  "description": "Residential solar PV monitoring - 5.24 kWp system with 2 micro inverters and 8 panels",
  "tags": ["solar", "energy", "influxdb"],
  "schemaVersion": 40,
  "version": 1,
  "timezone": "Asia/Bangkok",
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "editable": true,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Solar Power",
      "description": "Current total solar production from both inverters",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT SUM(solar_kw) AS solar_kw FROM (SELECT COALESCE(power_sensor, 0) / 1000.0 AS solar_kw FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1 UNION ALL SELECT COALESCE(power_sensor, 0) / 1000.0 AS solar_kw FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.001, "color": "yellow" },
              { "value": 1, "color": "green" },
              { "value": 4, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Today's Energy",
      "description": "Total energy produced today from both inverters",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT SUM(today_energy) AS today_kwh FROM (SELECT (COALESCE(MAX(today_production_1_sensor), 0) + COALESCE(MAX(today_production_2_sensor), 0) + COALESCE(MAX(today_production_3_sensor), 0) + COALESCE(MAX(today_production_4_sensor), 0)) AS today_energy FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '24 hours' UNION ALL SELECT (COALESCE(MAX(today_production_1_sensor), 0) + COALESCE(MAX(today_production_2_sensor), 0) + COALESCE(MAX(today_production_3_sensor), 0) + COALESCE(MAX(today_production_4_sensor), 0)) AS today_energy FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '24 hours')",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.1, "color": "yellow" },
              { "value": 10, "color": "green" },
              { "value": 25, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Lifetime Energy",
      "description": "Total cumulative energy produced since system installation",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT SUM(total_energy) AS lifetime_kwh FROM (SELECT (COALESCE(MAX(total_production_1_sensor), 0) + COALESCE(MAX(total_production_2_sensor), 0) + COALESCE(MAX(total_production_3_sensor), 0) + COALESCE(MAX(total_production_4_sensor), 0)) AS total_energy FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '1 hour' UNION ALL SELECT (COALESCE(MAX(total_production_1_sensor), 0) + COALESCE(MAX(total_production_2_sensor), 0) + COALESCE(MAX(total_production_3_sensor), 0) + COALESCE(MAX(total_production_4_sensor), 0)) AS total_energy FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '1 hour')",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Grid Import",
      "description": "Current power drawn from the grid via smart meter",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COALESCE(power_sensor, 0) / 1000.0 AS grid_kw FROM \"Smart Meter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.001, "color": "light-blue" },
              { "value": 1, "color": "blue" },
              { "value": 3, "color": "dark-blue" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "House Load",
      "description": "Current household power consumption (solar + grid import)",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT GREATEST(COALESCE(east.p, 0) + COALESCE(west.p, 0) + COALESCE(grid.p, 0), 0) / 1000.0 AS house_load_kw FROM (SELECT power_sensor AS p FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS east, (SELECT power_sensor AS p FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS west, (SELECT power_sensor AS p FROM \"Smart Meter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS grid",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.001, "color": "light-orange" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "dark-orange" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Self-Consumption",
      "description": "Percentage of house load covered by solar production",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CASE WHEN (COALESCE(east.p, 0) + COALESCE(west.p, 0) + COALESCE(grid.p, 0)) = 0 THEN 0 ELSE LEAST(GREATEST((COALESCE(east.p, 0) + COALESCE(west.p, 0)) / (COALESCE(east.p, 0) + COALESCE(west.p, 0) + COALESCE(grid.p, 0)), 0), 1) END AS self_consumption FROM (SELECT power_sensor AS p FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS east, (SELECT power_sensor AS p FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS west, (SELECT power_sensor AS p FROM \"Smart Meter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1) AS grid",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.3, "color": "yellow" },
              { "value": 0.7, "color": "green" },
              { "value": 1.0, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Peak Today",
      "description": "Maximum solar power achieved today",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT (COALESCE(east_max, 0) + COALESCE(west_max, 0)) / 1000.0 AS peak_kw FROM (SELECT MAX(power_sensor) AS east_max FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '24 hours'), (SELECT MAX(power_sensor) AS west_max FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '24 hours')",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" },
              { "value": 0.001, "color": "yellow" },
              { "value": 1, "color": "green" },
              { "value": 4, "color": "dark-green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 8,
      "title": "System Status",
      "description": "Current inverter operating state",
      "transparent": true,
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SOLAR}" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT device_state_sensor AS state FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '1 minute' ORDER BY time DESC LIMIT 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-gray" }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Standby", "color": "dark-gray" },
                "1": { "text": "Normal", "color": "green" },
                "2": { "text": "Warning", "color": "yellow" },
                "3": { "text": "Fault", "color": "red" }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "Offline", "color": "dark-gray" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Production",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "panels": []
    },
    {
      "type": "row",
      "id": 300,
      "title": "Module Level",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": []
    },
    {
      "type": "row",
      "id": 400,
      "title": "Grid & Consumption",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "panels": []
    },
    {
      "type": "row",
      "id": 500,
      "title": "Inverter Health",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "type": "row",
      "id": 600,
      "title": "Financial Savings",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "panels": []
    },
    {
      "type": "row",
      "id": 700,
      "title": "Event Log",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "panels": []
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
