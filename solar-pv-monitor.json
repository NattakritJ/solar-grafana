    {
      "type": "stat",
      "id": 6,
      "title": "Self-Consumption",
      "description": "Percentage of house load covered by solar production",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 1
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB_SOLAR}"
      },
      "targets": [
        {
          "refId": "East",
          "rawSql": "SELECT power_sensor AS east_w FROM \"East Microinverter\" ORDER BY time DESC LIMIT 1",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        },
        {
          "refId": "West",
          "rawSql": "SELECT power_sensor AS west_w FROM \"West Microinverter\" ORDER BY time DESC LIMIT 1",
          "format": "table",
          "datasource": {
            "type": "influxdb",
