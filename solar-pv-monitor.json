    {
      "type": "stat",
      "id": 1,
      "title": "Solar Power",
      "description": "Current total solar production from both inverters",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB_SOLAR}"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT power_sensor / 1000.0 AS solar_kw FROM \"East Microinverter\" ORDER BY time DESC LIMIT 1",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        },
        {
          "refId": "B",
          "rawSql": "SELECT power_sensor / 1000.0 AS solar_kw FROM \"West Microinverter\" ORDER BY time DESC LIMIT 1",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "dark-gray"
              },
              {
                "value": 0.001,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "green"
              },
              {
                "value": 4,
                "color": "dark-green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "value"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "sum"
            ]
          }
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Today's Energy",
      "description": "Total energy produced today from both inverters",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 1
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB_SOLAR}"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT (MAX(today_production_1_sensor) + MAX(today_production_2_sensor) + MAX(today_production_3_sensor) + MAX(today_production_4_sensor)) AS today_kwh FROM \"East Microinverter\" WHERE time >= now() - INTERVAL '24 hours'",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        },
        {
          "refId": "B",
          "rawSql": "SELECT (MAX(today_production_1_sensor) + MAX(today_production_2_sensor) + MAX(today_production_3_sensor) + MAX(today_production_4_sensor)) AS today_kwh FROM \"West Microinverter\" WHERE time >= now() - INTERVAL '24 hours'",
          "format": "table",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB_SOLAR}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "dark-gray"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "green"
              },
              {
                "value": 25,
                "color": "dark-green"
              }
            ]
          }
        },
        "overrides": []
      },
